# Copy to .env and export, or set in your shell / hosting dashboard.
# Never commit real secrets.

# SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=allergen-db
# DB_USER=your_user
# DB_PASSWORD=your_password

# JWT — required in prod (min 32 characters)
# APP_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# Optional
# PORT=8080
# APP_JWT_EXPIRATION_MS=86400000
# APP_JWT_COOKIE_SECURE=true
# APP_JWT_COOKIE_SAME_SITE=Lax
# APP_CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
