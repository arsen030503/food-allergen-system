# Dev-only: Vite proxies /api to this origin (see vite.config.js).
VITE_BACKEND_ORIGIN=http://localhost:8080

# Production: ensure the deployed index.html meta api-base matches your proxy, e.g.
# <meta name="api-base" content="/api" />
# Backend must list your site in APP_CORS_ALLOWED_ORIGINS if origins differ.
